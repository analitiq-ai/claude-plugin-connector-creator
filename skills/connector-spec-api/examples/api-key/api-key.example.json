{
  "$schema": "https://schemas.analitiq.ai/connector/latest.json",
  "kind": "api",
  "connector_id": "api-key-example",
  "display_name": "API Key Example",
  "description": "Reference connector demonstrating api_key auth with a fixed base_url.",
  "tags": [
    "example",
    "api",
    "api-key"
  ],
  "version": "1.0.0",
  "default_transport": "api",
  "transports": {
    "api": {
      "transport_type": "http",
      "base_url": "https://api.example.com/v1",
      "headers": {
        "Accept": "application/json",
        "Authorization": {
          "template": "Bearer ${secrets.api_key}"
        }
      },
      "timeout_seconds": 30,
      "rate_limit": {
        "max_requests": 100,
        "time_window_seconds": 1
      }
    }
  },
  "auth": {
    "type": "api_key"
  },
  "connection_contract": {
    "inputs": {
      "api_key": {
        "source": "user",
        "phase": "auth",
        "storage": "secrets",
        "type": "string",
        "required": true,
        "secret": true
      }
    }
  }
}
