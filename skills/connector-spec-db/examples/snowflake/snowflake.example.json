{
  "$schema": "https://schemas.analitiq.ai/connector/latest.json",
  "kind": "database",
  "connector_id": "snowflake-example",
  "display_name": "Snowflake Example",
  "description": "Reference connector for Snowflake using the ADBC snowflake driver.",
  "tags": [
    "example",
    "database",
    "snowflake",
    "warehouse",
    "adbc"
  ],
  "version": "1.0.0",
  "default_transport": "database",
  "transports": {
    "database": {
      "transport_type": "adbc",
      "driver": "snowflake",
      "db_kwargs": {
        "username": {
          "ref": "connection.parameters.username"
        },
        "password": {
          "ref": "secrets.password"
        },
        "adbc.snowflake.sql.account": {
          "ref": "connection.parameters.account"
        },
        "adbc.snowflake.sql.db": {
          "ref": "connection.parameters.database"
        },
        "adbc.snowflake.sql.schema": {
          "ref": "connection.parameters.schema"
        },
        "adbc.snowflake.sql.warehouse": {
          "ref": "connection.parameters.warehouse"
        },
        "adbc.snowflake.sql.role": {
          "ref": "connection.parameters.role"
        }
      }
    }
  },
  "auth": {
    "type": "db"
  },
  "connection_contract": {
    "inputs": {
      "account": {
        "source": "user",
        "phase": "pre_auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": true
      },
      "database": {
        "source": "user",
        "phase": "pre_auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": true
      },
      "schema": {
        "source": "user",
        "phase": "pre_auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": true,
        "default": "PUBLIC"
      },
      "warehouse": {
        "source": "user",
        "phase": "pre_auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": true
      },
      "role": {
        "source": "user",
        "phase": "pre_auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": false
      },
      "username": {
        "source": "user",
        "phase": "auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": true
      },
      "password": {
        "source": "user",
        "phase": "auth",
        "storage": "secrets",
        "type": "string",
        "required": true,
        "secret": true
      }
    }
  },
  "resource_discovery": {
    "strategy": "snowflake_account_usage",
    "transport_ref": "database",
    "implementation": {
      "type": "builtin"
    },
    "produces": [
      "connection.endpoints",
      "connection.type_map"
    ],
    "triggers": {
      "list_resources": "on_activation",
      "describe_resource": "on_resource_selected"
    }
  }
}
