{
  "$schema": "https://schemas.analitiq.ai/connector/latest.json",
  "kind": "api",
  "connector_id": "fixture-unknown-scope",
  "version": "1.0.0",
  "default_transport": "api",
  "transports": {
    "api": {
      "transport_type": "http",
      "base_url": "https://api.example.com",
      "headers": {
        "X-Bad-Ref": {
          "ref": "secret.api_key"
        },
        "X-Bad-Conn": {
          "ref": "connection.bogus.value"
        },
        "X-Bad-Template": {
          "template": "Bearer ${session.token}"
        },
        "X-Bad-Function": {
          "function": "hmac_sign",
          "input": {}
        }
      }
    }
  },
  "auth": {
    "type": "api_key"
  },
  "connection_contract": {
    "inputs": {
      "api_key": {
        "source": "user",
        "phase": "auth",
        "storage": "secrets",
        "type": "string",
        "required": true,
        "secret": true
      }
    }
  }
}
