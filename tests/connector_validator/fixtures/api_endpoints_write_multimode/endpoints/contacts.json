{
  "$schema": "https://schemas.analitiq.ai/api-endpoint/latest.json",
  "endpoint_id": "contacts",
  "operations": {
    "write": {
      "insert": {
        "request": { "method": "POST", "path": "/contacts" },
        "input": {
          "schema": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "native_type": "uuid", "arrow_type": "Utf8" }
            }
          }
        }
      },
      "upsert": {
        "request": { "method": "PUT", "path": "/contacts" },
        "input": {
          "schema": {
            "type": "object",
            "properties": {
              "updated_at": { "type": "string", "native_type": "date-time", "arrow_type": "Timestamp(MICROSECOND, UTC)" }
            }
          }
        }
      }
    }
  }
}
