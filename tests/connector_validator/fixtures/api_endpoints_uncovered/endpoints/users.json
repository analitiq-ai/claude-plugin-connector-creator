{
  "$schema": "https://schemas.analitiq.ai/api-endpoint/latest.json",
  "endpoint_id": "users",
  "operations": {
    "read": {
      "request": { "method": "GET", "path": "/users" },
      "response": {
        "records": { "ref": "response.body.data" },
        "schema": {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id":         { "type": "string", "native_type": "uuid",      "arrow_type": "Utf8" },
                  "is_admin":   { "type": "boolean","native_type": "boolean",   "arrow_type": "Boolean" },
                  "created_at": { "type": "string", "native_type": "date-time", "arrow_type": "Timestamp(MICROSECOND, UTC)" }
                }
              }
            }
          }
        }
      }
    }
  }
}
