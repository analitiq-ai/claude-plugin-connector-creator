{
  "$schema": "https://schemas.analitiq.ai/api-endpoint/latest.json",
  "endpoint_id": "contacts",
  "operations": {
    "write": {
      "insert": {
        "request": { "method": "POST", "path": "/contacts" },
        "input": {
          "schema": {
            "type": "object",
            "properties": {
              "id":         { "type": "string", "native_type": "uuid",      "arrow_type": "Utf8" },
              "created_at": { "type": "string", "native_type": "date-time", "arrow_type": "Timestamp(MICROSECOND, UTC)" }
            }
          }
        },
        "params": {
          "dry_run": {
            "in": "query", "type": "boolean", "required": false,
            "native_type": "boolean", "arrow_type": "Boolean"
          }
        }
      }
    }
  }
}
