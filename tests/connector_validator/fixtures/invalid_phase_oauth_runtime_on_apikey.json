{
  "$schema": "https://schemas.analitiq.ai/connector/latest.json",
  "kind": "api",
  "connector_id": "fixture-oauth-runtime-on-apikey",
  "version": "1.0.0",
  "default_transport": "api",
  "transports": {
    "api": {
      "transport_type": "http",
      "base_url": "https://api.example.com",
      "headers": {
        "Authorization": {
          "template": "Bearer ${secrets.api_key}"
        },
        "X-State": {
          "ref": "runtime.oauth.state"
        }
      }
    }
  },
  "auth": {
    "type": "api_key"
  },
  "connection_contract": {
    "inputs": {
      "api_key": {
        "source": "user",
        "phase": "auth",
        "storage": "secrets",
        "type": "string",
        "required": true,
        "secret": true
      }
    }
  }
}
