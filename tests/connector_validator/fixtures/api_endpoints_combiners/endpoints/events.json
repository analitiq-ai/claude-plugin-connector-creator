{
  "$schema": "https://schemas.analitiq.ai/api-endpoint/latest.json",
  "endpoint_id": "events",
  "operations": {
    "read": {
      "request": { "method": "GET", "path": "/events" },
      "response": {
        "records": { "ref": "response.body.events" },
        "schema": {
          "type": "object",
          "properties": {
            "events": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string", "native_type": "string", "arrow_type": "Utf8" },
                  "amount": {
                    "oneOf": [
                      { "type": "string",  "native_type": "ipv6",    "arrow_type": "Utf8" },
                      { "type": "integer", "native_type": "integer", "arrow_type": "Int64" }
                    ]
                  },
                  "tags": {
                    "type": "array",
                    "items": [
                      { "type": "string", "native_type": "email", "arrow_type": "Utf8" },
                      { "type": "string", "native_type": "uri",   "arrow_type": "Utf8" }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
