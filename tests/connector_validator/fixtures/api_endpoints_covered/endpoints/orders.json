{
  "$schema": "https://schemas.analitiq.ai/api-endpoint/latest.json",
  "endpoint_id": "orders",
  "operations": {
    "read": {
      "request": { "method": "GET", "path": "/orders" },
      "params": {
        "limit": {
          "in": "query", "type": "integer", "required": false, "default": 50,
          "native_type": "integer", "arrow_type": "Int64"
        }
      },
      "response": {
        "records": { "ref": "response.body.orders" },
        "schema": {
          "type": "object",
          "properties": {
            "orders": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id":        { "type": "string", "native_type": "uuid",      "arrow_type": "Utf8" },
                  "amount":    { "type": "number", "native_type": "number",    "arrow_type": "Float64" },
                  "placed_at": { "type": "string", "native_type": "date-time", "arrow_type": "Timestamp(MICROSECOND, UTC)" }
                }
              }
            }
          }
        }
      }
    }
  }
}
