{
  "$schema": "https://schemas.analitiq.ai/api-endpoint/latest.json",
  "endpoint_id": "items",
  "operations": {
    "read": {
      "request": { "method": "GET", "path": "/items" },
      "response": {
        "records": { "ref": "response.body.items" },
        "schema": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id":       { "type": "string", "native_type": "uuid", "arrow_type": "Int64" },
                  "metadata": {
                    "type": "object",
                    "native_type": "json",
                    "arrow_type": "Object",
                    "properties": {
                      "tag": { "type": "string", "native_type": "uuid", "arrow_type": "Utf8" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
