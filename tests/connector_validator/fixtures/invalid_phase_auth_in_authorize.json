{
  "$schema": "https://schemas.analitiq.ai/connector/latest.json",
  "kind": "api",
  "connector_id": "fixture-auth-scope-in-authorize",
  "version": "1.0.0",
  "default_transport": "api",
  "transports": {
    "api": {
      "transport_type": "http",
      "base_url": "https://api.example.com"
    }
  },
  "auth": {
    "type": "oauth2_authorization_code",
    "authorize": {
      "method": "GET",
      "path": {
        "template": "/oauth/authorize?token=${auth.access_token}"
      }
    },
    "token_exchange": {
      "method": "POST",
      "path": "/oauth/token"
    }
  },
  "connection_contract": {
    "inputs": {
      "client_id": {
        "source": "platform",
        "phase": "auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": true
      },
      "client_secret": {
        "source": "platform",
        "phase": "auth",
        "storage": "secrets",
        "type": "string",
        "required": true,
        "secret": true
      }
    }
  }
}
